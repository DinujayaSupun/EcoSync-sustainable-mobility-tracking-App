PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Get this from: https://cloud.mongodb.com/ → Database → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@clusterXXX.XXXXX.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/your_database?retryWrites=true&w=majority

# JWT Secret - Use a long random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# Client URL (Frontend)
CLIENT_URL=http://localhost:5173

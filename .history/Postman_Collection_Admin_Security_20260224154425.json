{
  "info": {
    "name": "Sustainability Project - Admin & Security APIs",
    "description": "Authentication and Admin Dashboard APIs with Security Features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass123\",\n  \"faculty\": \"Computing\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user with validation checks"
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"USER_TOKEN\", jsonData.token);",
                  "    console.log(\"User token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get JWT token"
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"ADMIN_TOKEN\", jsonData.token);",
                  "    console.log(\"Admin token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin and save token"
          },
          "response": []
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "profile"]
            },
            "description": "Get logged-in user profile (Protected Route)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Dashboard",
      "item": [
        {
          "name": "Get Admin Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/stats",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "stats"]
            },
            "description": "Get dashboard statistics (Admin Only)"
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/users",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "users"]
            },
            "description": "Get list of all users (Admin Only)"
          },
          "response": []
        },
        {
          "name": "Get Recent Trips",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/recent-trips?limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "recent-trips"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get recent commute trips for live feed (Admin Only)"
          },
          "response": []
        },
        {
          "name": "Generate Full Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/report",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "report"]
            },
            "description": "Generate comprehensive sustainability report (Admin Only)"
          },
          "response": []
        },
        {
          "name": "Generate Filtered Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/report?startDate=2026-02-01&endDate=2026-02-24&faculty=Computing",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "report"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2026-02-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-02-24"
                },
                {
                  "key": "faculty",
                  "value": "Computing"
                }
              ]
            },
            "description": "Generate filtered report by date and faculty (Admin Only)"
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/users/USER_ID_HERE",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "users", "USER_ID_HERE"]
            },
            "description": "Delete a user by ID (Admin Only) - Replace USER_ID_HERE with actual ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Security Testing",
      "item": [
        {
          "name": "Test No Token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/stats",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "stats"]
            },
            "description": "Should return 401 - No authorization token provided"
          },
          "response": []
        },
        {
          "name": "Test User Token on Admin Route (403)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/stats",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "stats"]
            },
            "description": "Should return 403 - User doesn't have admin role"
          },
          "response": []
        },
        {
          "name": "Test Invalid Token (401)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid_token_xyz123"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/admin/stats",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "admin", "stats"]
            },
            "description": "Should return 401 - Invalid token format"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Validation Testing",
      "item": [
        {
          "name": "Test Weak Password (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"weak\",\n  \"faculty\": \"Computing\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Should return 400 - Password must be at least 8 characters"
          },
          "response": []
        },
        {
          "name": "Test Invalid Email (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"notanemail\",\n  \"password\": \"StrongPass123\",\n  \"faculty\": \"Computing\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Should return 400 - Invalid email format"
          },
          "response": []
        },
        {
          "name": "Test Missing Fields (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Should return 400 - Missing required fields"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "USER_TOKEN",
      "value": "",
